---
import MainLayout from "../layouts/MainLayout.astro";

import Terminal from "../components/Terminal.astro";
import Accordion from "../components/Accordion.astro";
import ActionMenu from "../components/ActionMenu.astro";

import { sistemas } from "../data/sistemas";
---

<MainLayout
  title="Infraestructura y Sistemas"
  heading="Infraestructura y Sistemas"
  description=`
        Explora los fundamentos de la infraestructura tecnológica y los sistemas operativos. 
        Apuntes sobre hardware, redes, virtualización y despliegue de servidores. 
        Gestionar el entorno donde ejecutan las aplicaciones, asegurando estabilidad, seguridad y rendimiento en cada capa del stack tecnológico moderno actual.`
>
  <Terminal />

  <Accordion title="Arquitectura de hardware" sections={sistemas.hardware} />
  <Accordion title="Software de sistema y entornos de ejecución" sections={sistemas.software} />
  <Accordion title="Sistemas operativos: Linux(Ubuntu)" sections={sistemas.linux} />
  <Accordion title="Fundamentos de redes y comunicaciones" sections={sistemas.redes} />



  <ActionMenu />
</MainLayout>
