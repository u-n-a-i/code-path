---
import MainLayout from "../layouts/MainLayout.astro";

import Terminal from "../components/Terminal.astro";
import Accordion from "../components/Accordion.astro";
import ActionMenu from "../components/ActionMenu.astro";

import { home } from "../data/home";
---

<MainLayout
  title="Code Path"
  heading="Code-Path"
  description=`
        Este proyecto integra las rutas ASIR, DAM y DAW bajo un enfoque: el desarrollo de software. 
        Aquí encontrarás apuntes, recursos y ejemplos de código centralizados. 
        Todo el contenido está diseñado para aprender de forma progresiva. 
`
>
  <Terminal />

  <Accordion title="Bienvenida y Configuraciones" sections={home.bienvenida} />

  <ActionMenu />
</MainLayout>
