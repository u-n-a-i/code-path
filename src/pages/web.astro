---
import MainLayout from "../layouts/MainLayout.astro";

import Terminal from "../components/Terminal.astro";
import Accordion from "../components/Accordion.astro";
import ActionMenu from "../components/ActionMenu.astro";

import { web } from "../data/web";
---

<MainLayout
  title="Desarrollo Web"
  heading="Desarrollo Web"
  description=`
        Desarrolla interfaces interactivas y aplicaciones funcionales para internet. 
        Desde HTML y CSS hasta JavaScript y frameworks avanzados. 
        Esta ruta cubre frontend y backend para crear experiencias de usuario completas. 
        Construye proyectos reales dominando las herramientas más esenciales que usan los profesionales en la industria hoy.`
>
  <Terminal />

  <Accordion title="Estructura y semántica: HTML" sections={web.estructura} />

  <ActionMenu />
</MainLayout>
