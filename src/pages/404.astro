---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout webTitle="404 | Code-Path">
  <div class="not-found-container">
    <div class="wrapper">
      <h1 aria-label="Error cuatro cero cuatro">404</h1>
      <p>
        ¡Ups! La página que buscas se perdió en el Code-Path.<br />
        Pero no te preocupes, siempre puedes volver al inicio.
      </p>

      <a href="/" class="btn-home" aria-label="Volver a la página de inicio">
        ← Volver al inicio
      </a>
    </div>
  </div>
</MainLayout>

<style>
  .not-found-container {
    text-align: center;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--muted);
    border-radius: 12px;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
    width: 100%;
    max-width: 800px;
    height: 500px;
  }

  h1 {
    font-size: 4.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--danger);
    text-shadow: 0 0 12px var(--text-shadow);
    font-family: var(--mono);
    letter-spacing: -2px;
  }

  p {
    color: var(--fg);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-home {
    display: inline-block;
    color: var(--bg);
    background: var(--link);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    transition: all 0.25s ease;
    box-shadow: 0 4px 10px rgba(167, 240, 167, 0.3);
  }

  .btn-home:hover,
  .btn-home:focus {
    background: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(167, 240, 167, 0.45);
    outline: 2px solid var(--link);
    outline-offset: 4px;
  }

  .btn-home:active {
    transform: translateY(0);
  }
</style>
